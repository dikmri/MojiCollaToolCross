<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="MojiCollaTool.UpDownTextBox">
    <Grid ColumnDefinitions="1*,2*,1*">
        <RepeatButton x:Name="DownButton" Content="▼" MinWidth="28" FontSize="12" Grid.Column="0"
                      Click="DownButton_Click" PointerWheelChanged="Common_PointerWheelChanged"/>
        <TextBox x:Name="ValueTextBox" Text="0" VerticalContentAlignment="Center"
                 TextAlignment="Center" MinWidth="50" Grid.Column="1"
                 TextChanged="ValueTextBox_TextChanged"
                 PointerWheelChanged="Common_PointerWheelChanged"/>
        <RepeatButton x:Name="UpButton" Content="▲" MinWidth="28" FontSize="12" Grid.Column="2"
                      Click="UpButton_Click" PointerWheelChanged="Common_PointerWheelChanged"/>
    </Grid>
</UserControl>
