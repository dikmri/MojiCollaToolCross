<Application x:Class="MojiCollaTool.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:MojiCollaTool"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <!-- [0] テーマカラー（ThemeManager が起動時に Light/Dark に差し替える） -->
                <ResourceDictionary Source="Themes/ThemeColors.Light.xaml"/>
                <!-- [1] コントロールスタイル（固定） -->
                <ResourceDictionary Source="Themes/ControlStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <!-- フォーカス枠 -->
            <Style x:Key="FocusVisual">
                <Setter Property="Control.Template">
                    <Setter.Value>
                        <ControlTemplate>
                            <Rectangle Margin="2" StrokeDashArray="1 2"
                                       Stroke="{DynamicResource {x:Static SystemColors.ControlTextBrushKey}}"
                                       SnapsToDevicePixels="True" StrokeThickness="1"/>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- カラーピッカーボタン（文字色・縁取り色などの色表示ボタン）-->
            <!-- 通常の Button implicit style を継承し、TemplateBinding Background で選択色を表示する -->
            <Style x:Key="ColorButtonStyle" TargetType="{x:Type Button}" BasedOn="{StaticResource {x:Type Button}}">
                <!-- 各ボタンは inline で Background/BorderBrush/BorderThickness を設定する -->
            </Style>

        </ResourceDictionary>
    </Application.Resources>
</Application>
